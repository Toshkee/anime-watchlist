# ---------------------------------------------------------------------------
# Senpai — environment variables. Copy to `.env` (local) and fill in.
# AniList needs NO key for public reads, so search/browse runs out of the box.
# ---------------------------------------------------------------------------

# --- Database: PostgreSQL (Neon recommended for serverless/Vercel) ---
# Create a free project at https://neon.tech. Neon gives you two host strings:
#   • POOLED  (host has "-pooler") — use for DATABASE_URL (runtime queries)
#   • DIRECT  (no "-pooler")       — use for DIRECT_URL  (migrations)
# Locally (plain Postgres) both can point at the same database.
DATABASE_URL="postgresql://user:password@host-pooler/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth.js (NextAuth) ---
# Generate with: npx auth secret   (required in production)
AUTH_SECRET=""

# OAuth providers (optional — enable the ones you configure).
# Callback URL to register: https://<your-domain>/api/auth/callback/<provider>
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
